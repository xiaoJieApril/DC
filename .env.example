DISCORD_TOKEN=your_rotated_discord_bot_token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
SESSION_SECRET=change_this_to_a_long_random_string
PUBLIC_FRONTEND_ORIGIN=https://dc-gra-vt-bot.pages.dev
BOT_CONTROL_MODE=process
SYSTEMD_BOT_SERVICE=dc-gra-vt-bot
STORAGE_BACKEND=json
# Discord API protection (optional defaults)
DISCORD_CACHE_TTL_SECONDS=300
DISCORD_CACHE_STALE_SECONDS=86400
DISCORD_CLOUDFLARE_COOLDOWN_SECONDS=900
DISCORD_CLOUDFLARE_MAX_COOLDOWN_SECONDS=3600
DISCORD_MAX_CONCURRENT_REQUESTS=2
DISCORD_UPSTREAM_QUEUE_TIMEOUT_SECONDS=3
DISCORD_NEGATIVE_CACHE_SECONDS=60
DISCORD_AUTH_COOLDOWN_SECONDS=300
DISCORD_SHARED_REQUESTS_PER_SECOND=25
# Dashboard API protection (optional balanced defaults)
DASHBOARD_LOGIN_LIMIT_PER_MINUTE=5
DASHBOARD_LOCAL_READ_LIMIT_PER_MINUTE=120
DASHBOARD_LOCAL_WRITE_LIMIT_PER_MINUTE=30
DASHBOARD_DISCORD_READ_LIMIT_PER_MINUTE=30
DASHBOARD_DISCORD_WRITE_LIMIT_PER_MINUTE=10
DASHBOARD_IDEMPOTENCY_TTL_SECONDS=300
